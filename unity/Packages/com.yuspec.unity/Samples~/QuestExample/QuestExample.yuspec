entity Player {
    inventory = []
}

entity Quest {
    state = Inactive
}

on Player.EnterVillageGate:
    set Quest.state = Active
    start_quest "FindTheBlacksmith"

on Player.EnterBlacksmithHouse when Quest.state == Active:
    set Quest.state = Complete
    complete_quest "FindTheBlacksmith"
    give Player "BlacksmithToken"

scenario "quest completes at blacksmith house" {
    given Quest state = Active
    when Player.EnterBlacksmithHouse
    expect Quest.state == Complete
}
