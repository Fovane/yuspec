{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "YUSPEC",
  "scopeName": "source.yuspec",
  "patterns": [
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#compoundExpressions"
    },
    {
      "include": "#stateTransitions"
    },
    {
      "include": "#propertyAccess"
    },
    {
      "include": "#timeLiterals"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.yuspec",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.yuspec",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.yuspec",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.yuspec",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.yuspec",
          "match": "\\b(entity|on|when|behavior|state|scenario|given|expect|every|has|set|do|with|from|dialogue|line|choice|for|start_dialogue|end)\\b"
        },
        {
          "name": "storage.type.yuspec",
          "match": "\\b(int|float|bool|string)(?:\\[\\])?"
        },
        {
          "name": "constant.language.boolean.yuspec",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "compoundExpressions": {
      "patterns": [
        {
          "name": "meta.event-handler.yuspec",
          "match": "\\bon\\s+([A-Z][A-Za-z0-9_]*)\\.([A-Za-z_][A-Za-z0-9_]*)(?:\\s+with\\s+([A-Z][A-Za-z0-9_]*))?",
          "captures": {
            "1": {
              "name": "entity.name.type.yuspec"
            },
            "2": {
              "name": "entity.name.function.event.yuspec"
            },
            "3": {
              "name": "entity.name.type.yuspec"
            }
          }
        }
      ]
    },
    "stateTransitions": {
      "patterns": [
        {
          "name": "keyword.operator.transition.yuspec",
          "match": "->"
        }
      ]
    },
    "propertyAccess": {
      "patterns": [
        {
          "name": "variable.other.property-access.yuspec",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"
        },
        {
          "name": "entity.name.type.yuspec",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "timeLiterals": {
      "patterns": [
        {
          "name": "constant.numeric.time.yuspec",
          "match": "\\b\\d+(?:\\.\\d+)?(?:ms|s|min)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.yuspec",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    }
  }
}
